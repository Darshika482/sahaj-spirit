# ─── RAZORPAY ────────────────────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_chosen_webhook_secret

# ─── REGISTRATION ─────────────────────────────────────────────────────────────
VITE_REGISTRATION_FEE=1000

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# In Supabase Dashboard → Authentication → URL Configuration, set:
#   Site URL: https://www.sahajspirit.com
#   Redirect URLs (add all):
#     https://www.sahajspirit.com/admin
#     https://sahajspirit.com/admin
#     http://localhost:3000/admin
#     http://localhost:3001/admin
#
# Content editor: when SUPABASE_SERVICE_ROLE_KEY is set, local and production
# admin both read/write the same site-content.json in Supabase Storage.

# ─── ADMIN (Google OAuth via Supabase) ────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=4000
